// Event-to-ICS App - Prisma schema
// SQLite local database for AI settings storage only.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Generic key-value store for app settings (AI provider config).
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}